{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT}/deep-plan ${CLAUDE_PLUGIN_ROOT}/deep-plan/scripts/hooks/capture-session-id.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT}/deep-plan ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-compact-snapshot.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/track-subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "deep-plan:section-writer",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT}/deep-plan ${CLAUDE_PLUGIN_ROOT}/deep-plan/scripts/hooks/write-section-on-stop.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/track-subagent-stop.sh"
          }
        ]
      }
    ]
  }
}
